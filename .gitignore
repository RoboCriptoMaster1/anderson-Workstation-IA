# =============================================================================
# Workstation IA
# .gitignore
# Versão: 2.0
#
# Objetivo:
# Impedir que arquivos temporários, credenciais, caches, logs e artefatos de
# desenvolvimento sejam enviados ao repositório Git.
# =============================================================================

# =============================================================================
# SEGURANÇA - Credenciais e Chaves
# =============================================================================

*.key
*.pem
*.p12
*.pfx
*.crt
*.csr

.env
.env.*
.env.local
.env.development
.env.production
.env.test

*secret*
*credential*
*password*
*token*

chave*API*
chave*.txt
*api*key*.txt

# =============================================================================
# CLAUDE CODE
# =============================================================================

.claude/settings.local.json

# =============================================================================
# PYTHON
# =============================================================================

__pycache__/

*.py[cod]
*.pyo
*.pyd

*.egg-info/

.venv/
venv/
env/

.pytest_cache/
.mypy_cache/

.ipynb_checkpoints/

.coverage
htmlcov/

# =============================================================================
# NODE.JS
# =============================================================================

node_modules/

npm-debug.log*
yarn-error.log*
pnpm-debug.log*

dist/
build/

coverage/

# =============================================================================
# SQLITE
# =============================================================================

*.db
*.sqlite
*.sqlite3

# =============================================================================
# VISUAL STUDIO CODE
# =============================================================================

.vscode/

# =============================================================================
# JETBRAINS
# =============================================================================

.idea/

# =============================================================================
# VISUAL STUDIO
# =============================================================================

.vs/

# =============================================================================
# EXCEL / MICROSOFT OFFICE
# =============================================================================

~$*.xlsx
~$*.xlsm
~$*.xls
~$*.docx
~$*.pptx

*.tmp

# =============================================================================
# LOGS
# =============================================================================

*.log

logs/

# =============================================================================
# BACKUPS
# =============================================================================

*.bak
*.old
*.backup

# =============================================================================
# ARQUIVOS COMPACTADOS
# =============================================================================

*.zip
*.7z
*.rar
*.tar
*.gz

# =============================================================================
# WINDOWS
# =============================================================================

Thumbs.db
Desktop.ini

$RECYCLE.BIN/

# =============================================================================
# macOS
# =============================================================================

.DS_Store
.AppleDouble
.LSOverride

# =============================================================================
# LINUX
# =============================================================================

*~

.nfs*

# =============================================================================
# GIT
# =============================================================================

*.orig

